generator client {
  provider = "prisma-client"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  EMPLOYEE
  PROPERTY_ADMIN
  PROPERTY_OWNER
  PROPERTY_RESIDENT
  PROPERTY_VIEWER
  COLLABORATOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CompanyStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
}

enum SubscriptionTier {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  PENDING
  CANCELLED
  EXPIRED
}

enum UnitType {
  APARTMENT
  SHOP
  PARKING
  OTHER
}

// Users table - all users in the system
model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  name                String?
  passwordHash        String?
  role                UserRole
  status              UserStatus @default(ACTIVE)

  // Company association (null for SUPER_ADMIN)
  companyId           String?
  company             Company? @relation("users", fields: [companyId], references: [id], onDelete: SetNull)

  // Property association (for property-specific roles)
  propertyId          String?
  property            Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  // Unit association (for residents/owners)
  ownedUnits          Unit[] @relation("owner")
  residentUnits       Unit[] @relation("resident")

  // Relationships for multi-role users
  companyRoles        UserCompanyRole[]

  // Companies created by this user (for SUPER_ADMIN)
  createdCompanies    Company[] @relation("createdCompanies")

  // Menu configs created by this user
  createdMenuConfigs  MenuConfig[] @relation("menuConfigCreatedBy")

  // Announcements created by this user
  createdAnnouncements Announcement[] @relation("announcementCreatedBy")

  // Maintenance requests reported by this user
  reportedMaintenance MaintenanceRequest[] @relation("maintenanceReportedBy")

  // Maintenance requests assigned to this user
  assignedMaintenance MaintenanceRequest[] @relation("maintenanceAssignedTo")

  // Audit fields
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  lastLoginAt         DateTime?

  // Auth.js session support
  accounts            Account[]
  sessions            Session[]

  @@index([email])
  @@index([companyId])
  @@index([propertyId])
}

// Auth.js Account model
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Auth.js Session model
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Verification token for password reset, email verification
model VerificationToken {
  id          String   @id @default(cuid())
  email       String
  token       String   @unique
  expires     DateTime
  type        String   // 'password-reset' or 'email-verification'

  @@index([email])
  @@index([token])
}

// Companies (Tenants) - SaaS customers
model Company {
  id                    String   @id @default(cuid())
  name                  String
  slug                  String   @unique
  logoUrl               String?  // BunnyCDN URL

  // Subscription details
  subscriptionTier      SubscriptionTier @default(STARTER)

  // Limits
  maxProperties         Int      @default(1)
  maxUsers              Int      @default(5)
  maxStorage            Int      @default(10) // GB

  // Status
  status                CompanyStatus @default(TRIAL)
  trialEndsAt           DateTime?

  // Relations
  createdById           String?
  createdBy             User?    @relation("createdCompanies", fields: [createdById], references: [id], onDelete: SetNull)

  users                 User[] @relation("users")
  properties            Property[]
  subscription          Subscription?
  addonFeatures         AddonFeature[]
  menuConfigs           MenuConfig[]
  userRoles             UserCompanyRole[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([slug])
  @@index([status])
}

// Subscriptions - billing records
model Subscription {
  id                    String   @id @default(cuid())

  // Company link
  companyId             String   @unique
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Billing details
  vivaBatchId           String?  // Viva Payments reference
  tier                  SubscriptionTier
  billingCycle          BillingCycle
  amount                Float    // EUR
  currency              String   @default("EUR")
  status                SubscriptionStatus @default(ACTIVE)

  // Dates
  startDate             DateTime
  endDate               DateTime
  renewalDate           DateTime

  // Trial info
  trialDays             Int?
  trialUsed             Int      @default(0)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([companyId])
  @@index([status])
}

// Add-on Features - premium features purchased per property
model AddonFeature {
  id                    String   @id @default(cuid())

  companyId             String
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  propertyId            String?
  property              Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  // Feature type
  featureKey            String   // 'analytics', 'api', 'sms', 'whitelabel'
  featureName           String
  description           String?

  // Billing
  monthlyPrice          Float
  billingCycle          BillingCycle @default(MONTHLY)
  active                Boolean  @default(true)

  activatedAt           DateTime @default(now())
  expiresAt             DateTime?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([companyId, propertyId, featureKey])
  @@index([companyId])
  @@index([propertyId])
}

// Properties - buildings/complexes
model Property {
  id                    String   @id @default(cuid())

  companyId             String
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Basic info
  name                  String
  address               String
  city                  String
  postalCode            String
  country               String   @default("Greece")
  imageUrl              String?  // BunnyCDN URL

  // Details
  unitsCount            Int      @default(0)

  // Relations
  users                 User[]
  units                 Unit[]
  addons                AddonFeature[]
  announcements         Announcement[]
  maintenanceRequests   MaintenanceRequest[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([companyId])
  @@index([name])
}

// Units - apartments, shops, parking spaces
model Unit {
  id                    String   @id @default(cuid())

  propertyId            String
  property              Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // Basic info
  unitNumber            String
  unitType              UnitType @default(APARTMENT)
  floor                 Int?

  // Ownership
  ownerId               String?
  owner                 User?    @relation("owner", fields: [ownerId], references: [id], onDelete: SetNull)

  residentId            String?
  resident              User?    @relation("resident", fields: [residentId], references: [id], onDelete: SetNull)

  // Relations
  maintenanceRequests   MaintenanceRequest[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([propertyId, unitNumber])
  @@index([propertyId])
  @@index([ownerId])
  @@index([residentId])
}

// User Company Role - for multi-role support
model UserCompanyRole {
  id                    String   @id @default(cuid())

  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyId             String
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  role                  UserRole
  department            String?  // For MANAGER/EMPLOYEE
  position              String?  // For EMPLOYEE

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
}

// Menu Configuration - SUPER_ADMIN configures menus per role
model MenuConfig {
  id                    String   @id @default(cuid())

  companyId             String?
  company               Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  role                  UserRole
  menuItems             Json     // Array of menu item objects
  isDefault             Boolean  @default(true)

  createdById           String?
  createdBy             User?    @relation("menuConfigCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([companyId, role])
  @@index([role])
}

// Announcements - digital signage content
model Announcement {
  id                    String   @id @default(cuid())

  propertyId            String
  property              Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  title                 String
  content               String   @db.Text
  imageUrl              String?  // BunnyCDN URL

  status                String   @default("ACTIVE") // ACTIVE, DRAFT, ARCHIVED

  publishedAt           DateTime?
  expiresAt             DateTime?

  createdById           String?
  createdBy             User?    @relation("announcementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([propertyId])
  @@index([status])
}

model Announcement_User {
  id                    String   @id @default(cuid())
  announcementId        String
  userId                String
  readAt                DateTime?

  @@unique([announcementId, userId])
}

// Maintenance Requests - core feature
model MaintenanceRequest {
  id                    String   @id @default(cuid())

  propertyId            String
  property              Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  unitId                String?
  unit                  Unit?    @relation(fields: [unitId], references: [id], onDelete: SetNull)

  title                 String
  description           String   @db.Text

  category              String   // 'plumbing', 'electrical', 'general', etc.
  priority              String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  status                String   @default("OPEN") // OPEN, IN_PROGRESS, COMPLETED, CANCELLED

  reportedById          String?
  reportedBy            User?    @relation("maintenanceReportedBy", fields: [reportedById], references: [id], onDelete: SetNull)

  assignedToId          String?
  assignedTo            User?    @relation("maintenanceAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  attachmentUrl         String?  // BunnyCDN URL

  scheduledDate         DateTime?
  completedAt           DateTime?
  notes                 String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([propertyId])
  @@index([unitId])
  @@index([status])
  @@index([priority])
}
