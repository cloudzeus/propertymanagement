model ContactMessage {
  id                    String   @id @default(cuid())
  name                  String
  email                 String
  phone                 String?
  subject               String
  message               String   @db.Text
  status                String   @default("NEW") // NEW, READ, RESPONDED, SPAM
  ipAddress             String?
  userAgent             String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model CookieConsent {
  id                    String   @id @default(cuid())
  sessionId             String   @unique // Browser session identifier
  analytics             Boolean  @default(false)
  marketing             Boolean  @default(false)
  functional            Boolean  @default(false)
  essential             Boolean  @default(true) // Always true
  consentedAt           DateTime @default(now())
  expiresAt             DateTime // Consent valid for 12 months
  ipAddress             String?
  userAgent             String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([sessionId])
  @@index([expiresAt])
}

// App-wide brand & settings — always one row (id = "singleton")
