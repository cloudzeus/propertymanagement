generator client {
  provider = "prisma-client"
  output   = "../lib/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  EMPLOYEE
  PROPERTY_ADMIN
  PROPERTY_OWNER
  PROPERTY_RESIDENT
  PROPERTY_VIEWER
  COLLABORATOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CompanyStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
}

enum SubscriptionTier {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  PENDING
  CANCELLED
  EXPIRED
}

enum UnitType {
  APARTMENT
  SHOP
  PARKING
  OTHER
}

// Customer (πελάτης) — individual or company that is billed for our services
enum CustomerType {
  INDIVIDUAL
  COMPANY
}

// How a catalog Service is priced (all charges are monthly)
enum ServicePricingModel {
  PER_UNIT         // × number of units (apartments+shops) — used by CORE
  PER_BUILDING     // × number of buildings
  PER_COMMON_AREA  // × number of common areas
  FLAT             // fixed monthly amount
  METERED_PREPAID  // usage-based with prepaid balance (assemblies: minutes × participants)
}

// Status of a monthly service invoice to a Customer
enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum ExpenseUtilityType {
  NONE
  POWER
  WATER
  GAS
}

enum ExpenseStatus {
  DRAFT
  CONFIRMED
  ISSUED
}

enum ExpensePaymentMethod {
  CARD
  CASH
  VIVA
  BANK_TRANSFER
  CHECK
  OTHER
}

enum MeterType {
  POWER
  WATER
  GAS
}

// Users table - all users in the system
model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  name                String?
  phone               String?
  mobile              String?
  passwordHash        String?
  role                UserRole
  status              UserStatus @default(ACTIVE)

  // Company association (null for SUPER_ADMIN)
  companyId           String?
  company             Company? @relation("users", fields: [companyId], references: [id], onDelete: SetNull)

  // Customer association (for the customer's manager/staff users)
  customerId          String?
  customer            Customer? @relation("customerUsers", fields: [customerId], references: [id], onDelete: SetNull)

  // Building association (for building-specific roles, e.g. building manager)
  buildingId          String?
  building            Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)

  // Unit association (for residents/owners)
  ownedUnits          Unit[] @relation("owner")
  residentUnits       Unit[] @relation("resident")
  occupancies         UnitOccupancy[] @relation("userOccupancies")
  infraKeyOf          InfraPoint[] @relation("infraKeyHolder")
  infraAccess         InfraAccess[] @relation("infraAccess")

  // Relationships for multi-role users
  companyRoles        UserCompanyRole[]

  // Companies created by this user (for SUPER_ADMIN)
  createdCompanies    Company[] @relation("createdCompanies")

  // Menu configs created by this user
  createdMenuConfigs  MenuConfig[] @relation("menuConfigCreatedBy")

  // Announcements created by this user
  createdAnnouncements Announcement[] @relation("announcementCreatedBy")
  announcementAcks     Announcement_User[] @relation("announcementAcks")

  // Employee records linked to this user
  employeeLinks       Employee[] @relation("employeeUser")

  // Maintenance requests reported by this user
  reportedMaintenance MaintenanceRequest[] @relation("maintenanceReportedBy")

  // Maintenance requests assigned to this user
  assignedMaintenance MaintenanceRequest[] @relation("maintenanceAssignedTo")

  // API usage logs triggered by this user
  apiUsageLogs        APIUsageLog[]

  // Per-scope management assignments (διαχειριστής of a property/building)
  managementAssignments ManagementAssignment[] @relation("userManagements")

  // Audit fields
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  lastLoginAt         DateTime?

  // Auth.js session support
  accounts            Account[]
  sessions            Session[]

  @@index([email])
  @@index([companyId])
  @@index([customerId])
  @@index([buildingId])
}

// Auth.js Account model
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Auth.js Session model
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Verification token for password reset, email verification
model VerificationToken {
  id          String   @id @default(cuid())
  email       String
  token       String   @unique
  expires     DateTime
  type        String   // 'password-reset' or 'email-verification'

  @@index([email])
  @@index([token])
}

// Companies (Tenants) - SaaS customers
model Company {
  id                    String   @id @default(cuid())
  name                  String
  slug                  String   @unique
  logoUrl               String?

  // Subscription details
  subscriptionTier      SubscriptionTier @default(STARTER)

  // Limits
  maxProperties         Int      @default(1)
  maxUsers              Int      @default(5)
  maxStorage            Int      @default(10)

  // Status
  status                CompanyStatus @default(TRIAL)
  trialEndsAt           DateTime?

  // ── Business profile (SoftOne COMPANY aligned) ───────────────────────────
  // Identity
  afm                   String?   // ΑΦΜ
  taxOffice             String?   // ΔΟΥ
  legalName             String?   // Εναλλακτική επωνυμία (NAME2)
  legalForm             String?   // Νομική μορφή (ΑΕ, ΙΚΕ, ΕΠΕ…)
  activity              String?   // Αντικείμενο δραστηριότητας
  title                 String?   // Τίτλος (SOTITLE)

  // Address
  address               String?
  district              String?   // Νομός/Περιοχή
  city                  String?
  postalCode            String?
  country               String?   @default("Ελλάδα")
  lat                   Float?
  lng                   Float?

  // Contact
  phone1                String?
  phone2                String?
  phone3                String?
  fax                   String?
  email                 String?
  website               String?

  // Identity extras
  glnCode               String?   // GLNCODE — GLN
  registryNumber        String?   // NUMBERM — Αριθ. μητρώου
  vatStatus             String?   // VATSTS  — Καθεστώς ΦΠΑ (Κανονικό/Απαλλαγμένο…)
  distStats             String?   // DISTSTATS — Υ.Σ.Ν.

  // Registration
  gemhNumber            String?   // NUMCG   — ΓΕΜΗ
  ikaNumber             String?   // IKA     — Ε.Φ.Κ.Α. υποκατάστημα
  ikaRegistry           String?   // IKAM    — Μητρώο Ε.Φ.Κ.Α.
  folderNumber          String?   // FOLDERNUM — Αρ. φακέλου
  kadCode               String?   // KAD     — ΚΑΔ

  // Dates
  foundedAt             DateTime? // CRTDATE — Ίδρυση
  dissolutionDate       DateTime? // FNLDATE — Λύση

  // Financial
  iban                  String?
  bank                  String?
  initialCapital        Float?    // INITCAPITAL
  paidCapital           Float?    // PAIDCAPITAL

  // Legal representative
  legalRep              String?   // CFONAME     — Πρόεδρος Δ.Σ.
  legalRepId            String?   // IDENTITYNUM — Α.Δ.Τ.

  // HR / Social security
  tpte                  String?   // TPTE        — Τ.Π.Τ.Ε e-Ε.Φ.Κ.Α.
  tpteteka              String?   // TPTETEKA    — Τ.Π.Τ.Ε Τ.Ε.Κ.Α
  employmentOrg         String?   // ERGORGANOSI — Εργοδοτική οργάνωση

  // Misc
  remarks               String?   @db.Text // REMARKS — Παρατηρήσεις

  // SoftOne integration
  softoneCompanyCode    Int?      // COMPANY.COMPANY code in SoftOne ERP
  // ─────────────────────────────────────────────────────────────────────────

  // Relations
  createdById           String?
  createdBy             User?    @relation("createdCompanies", fields: [createdById], references: [id], onDelete: SetNull)

  users                 User[] @relation("users")
  customers             Customer[]
  properties            Property[]
  buildings             Building[]
  services              Service[]
  subscription          Subscription?
  addonFeatures         AddonFeature[]
  menuConfigs           MenuConfig[]
  userRoles             UserCompanyRole[]
  apiUsageLogs          APIUsageLog[]
  costSummaries         MonthlyCostSummary[]
  departments           Department[]
  jobPositions          JobPosition[]
  employees             Employee[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([slug])
  @@index([status])
}

// Departments (Τμήματα εταιρείας)
model Department {
  id            String      @id @default(cuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  description   String?     @db.Text
  isActive      Boolean     @default(true)
  sortOrder     Int         @default(0)

  positions     JobPosition[]
  employees     Employee[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([companyId])
}

// Job Positions (Θέσεις εργασίας)
model JobPosition {
  id            String      @id @default(cuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  title         String
  description   String?     @db.Text
  level         String?     // Junior, Senior, Manager, Director, Executive
  isActive      Boolean     @default(true)

  employees     Employee[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([companyId])
  @@index([departmentId])
}

// Employees (Υπάλληλοι)
model Employee {
  id              String         @id @default(cuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departmentId    String?
  department      Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  jobPositionId   String?
  jobPosition     JobPosition?   @relation(fields: [jobPositionId], references: [id], onDelete: SetNull)

  // Linked application user account (optional)
  userId          String?
  user            User?          @relation("employeeUser", fields: [userId], references: [id], onDelete: SetNull)

  // Personal
  firstName       String
  lastName        String
  email           String?
  phone           String?
  mobile          String?

  // Employment
  employeeCode    String?
  hireDate        DateTime?
  terminationDate DateTime?
  status          EmployeeStatus @default(ACTIVE)

  // Tax / Social security
  afm             String?
  amka            String?
  ikaNumber       String?

  // Address
  address         String?
  city            String?
  postalCode      String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([companyId])
  @@index([departmentId])
  @@index([jobPositionId])
  @@index([userId])
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

// Subscriptions - billing records
model Subscription {
  id                    String   @id @default(cuid())

  // Company link
  companyId             String   @unique
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Billing details
  vivaBatchId           String?  // Viva Payments reference
  tier                  SubscriptionTier
  billingCycle          BillingCycle
  amount                Float    // EUR
  currency              String   @default("EUR")
  status                SubscriptionStatus @default(ACTIVE)

  // Dates
  startDate             DateTime
  endDate               DateTime
  renewalDate           DateTime

  // Trial info
  trialDays             Int?
  trialUsed             Int      @default(0)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([companyId])
  @@index([status])
}

// Add-on Features - premium features purchased per property
model AddonFeature {
  id                    String   @id @default(cuid())

  companyId             String
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  buildingId            String?
  building              Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)

  // Feature type
  featureKey            String   // 'analytics', 'api', 'sms', 'whitelabel'
  featureName           String
  description           String?

  // Billing
  monthlyPrice          Float
  billingCycle          BillingCycle @default(MONTHLY)
  active                Boolean  @default(true)

  activatedAt           DateTime @default(now())
  expiresAt             DateTime?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([companyId, buildingId, featureKey])
  @@index([companyId])
  @@index([buildingId])
}

// Customer (πελάτης) — individual or company billed for our services.
// Owns one or more Properties; is the target of service invoicing.
model Customer {
  id                    String   @id @default(cuid())

  companyId             String
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  type                  CustomerType @default(INDIVIDUAL)

  // ── SoftOne TRDR alignment (future ERP sync) ─────────────────────────────
  // SODTYPE distinguishes trading-partner kind in SoftOne's shared TRDR table:
  //   13 = Πελάτης (Customer)  ·  12 = Προμηθευτής (Supplier)
  sodType               Int      @default(13) // SODTYPE — 13 customer / 12 supplier
  softoneTrdr           Int?     // TRDR (AutoInc PK in SoftOne) — link for sync
  code                  String?  // CODE — Κωδικός συναλλασσόμενου
  // ─────────────────────────────────────────────────────────────────────────

  // Identity / billing (TRDR-aligned)
  name                  String   // NAME — Επωνυμία (company) / full name (individual)
  afm                   String?  // AFM — ΑΦΜ
  doy                   String?  // IRSDATA — ΔΟΥ
  email                 String?  // EMAIL
  phone                 String?  // PHONE01 — Τηλ.1
  phone2                String?  // PHONE02 — Τηλ.2
  fax                   String?  // FAX
  webpage               String?  // WEBPAGE
  address               String?  // ADDRESS — Διεύθυνση
  city                  String?  // CITY — Πόλη
  district              String?  // DISTRICT — Περιοχή
  postalCode            String?  // ZIP — Τ.Κ.
  country               String?  // COUNTRY (SoftOne uses Smallint code; stored as text here)
  isActive              Boolean  @default(true) // ISACTIVE
  remarks               String?  // REMARKS — Παρατηρήσεις

  // Geodata (geocoded from the address)
  lat                   Float?
  lng                   Float?

  // Relations
  users                 User[]   @relation("customerUsers")
  properties            Property[]
  invoices              ServiceInvoice[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([companyId, softoneTrdr])
  @@index([companyId])
  @@index([sodType])
  @@index([afm])
}

// Property (Ιδιοκτησία) — a customer's holding; can contain MANY buildings.
// The service package and billing live at this level.
model Property {
  id                    String   @id @default(cuid())

  companyId             String
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId            String
  customer              Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  name                  String
  notes                 String?

  // Address & geodata
  address               String?
  city                  String?
  postalCode            String?
  country               String?  @default("Ελλάδα")
  lat                   Float?
  lng                   Float?

  // Optional OWN Viva account — κοινόχρηστα are managed INDEPENDENTLY per property,
  // so residents' κοινόχρηστα payments go to this property's own Viva account.
  vivaEnabled           Boolean  @default(false)
  vivaMerchantId        String?
  vivaApiKeyEnc         String?  // stored encrypted
  vivaSourceCode        String?

  // Relations
  buildings             Building[]
  services              PropertyService[]
  managementAssignments ManagementAssignment[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([companyId])
  @@index([customerId])
  @@index([name])
}

enum MillesimeSource {
  AUTO
  MANUAL
}

enum DistributionBasis {
  GENERAL_MILLESIMES
  ELEVATOR_MILLESIMES
  HEATING_MILLESIMES
  EQUAL_PER_UNIT
  METERED_70_30
}

// Building (Κτήριο) — a physical building under a Property.
model Building {
  id                    String   @id @default(cuid())

  companyId             String
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  propertyId            String
  property              Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // Basic info
  name                  String
  address               String
  city                  String
  postalCode            String
  country               String   @default("Greece")
  imageUrl              String?  // BunnyCDN URL

  // Details
  floors                Int?     // above-ground όροφοι (excludes ισόγειο)
  basements             Int?     // υπόγεια (number of basement levels)
  unitsCount            Int      @default(0)

  // Technical
  hasElevator           Boolean  @default(false)
  hasBoiler             Boolean  @default(false)
  hasFireSafety         Boolean  @default(false)
  technicalNotes        String?

  // Elevator floor parameters (κοινόχρηστα ασανσέρ)
  elevatorSurchargePerFloor  Float   @default(0.10)
  elevatorExemptGroundFloor  Boolean @default(true)
  heatingMeterUnit           String?

  // Geodata
  lat                   Float?
  lng                   Float?

  // Relations
  users                 User[]
  units                 Unit[]
  commonAreas           CommonArea[]
  addons                AddonFeature[]
  announcements         Announcement[]
  dailyRoomName         String?
  assemblies            Assembly[]
  maintenanceRequests   MaintenanceRequest[]
  managementAssignments ManagementAssignment[]
  files                 BuildingFile[]
  infraPoints           InfraPoint[]
  contacts              Contact[]
  recurringTasks        RecurringTask[]
  expenses              BuildingExpense[]
  categoryOverrides     BuildingCategoryOverride[]
  meterReadings         MeterReading[]
  heatingReadings       UnitHeatingReading[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([companyId])
  @@index([propertyId])
  @@index([name])
}

// ── Building control-center sub-entities ─────────────────────────────────────

enum OccupancyRole {
  OWNER
  RESIDENT
}

// Occupancy timeline per unit — residents/owners change over time (από/έως).
// The "current" occupant of a role is the row with endDate = null.
model UnitOccupancy {
  id          String   @id @default(cuid())
  unitId      String
  unit        Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation("userOccupancies", fields: [userId], references: [id], onDelete: Cascade)
  role        OccupancyRole
  startDate   DateTime @default(now())
  endDate     DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  @@index([unitId])
  @@index([userId])
  @@index([unitId, role, endDate])
}

enum BuildingFileCategory {
  PLANS
  PHOTOS
  DOCUMENTS
  CERTIFICATES
  RECEIPT
  PAYMENT
  OTHER
}

model BuildingFile {
  id          String   @id @default(cuid())
  buildingId  String
  building    Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  category    BuildingFileCategory @default(OTHER)
  name        String
  cdnPath     String   // storage path inside the building folder
  url         String   // public CDN url
  mimeType    String?
  sizeBytes   Int?
  uploadedById String?
  createdAt   DateTime @default(now())
  expenseLinks BuildingExpense[] @relation("expenseReceipt")
  paymentLinks BuildingExpense[] @relation("expensePayment")
  @@index([buildingId])
  @@index([buildingId, category])
}

enum InfraType {
  ELECTRICITY
  OTE
  ROOF
  ANTENNA
  BOILER
  PUMP
  FIRE
  WATER
  OTHER
}

model InfraPoint {
  id          String   @id @default(cuid())
  buildingId  String
  building    Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  name        String
  type        InfraType @default(OTHER)
  floorLabel  String?
  location    String?
  locked      Boolean  @default(false)
  accessNotes String?  // legacy free-text (superseded by access[])
  keyHolder   String?  // legacy free-text (superseded by keyHolderUser)
  photoUrl    String?  // legacy cover (superseded by media[])
  notes       String?

  // Key holder = a specific user (owner/resident/manager/employee)
  keyHolderUserId String?
  keyHolderUser   User?    @relation("infraKeyHolder", fields: [keyHolderUserId], references: [id], onDelete: SetNull)

  // Who has access (many users) + media (many photos/videos)
  access      InfraAccess[]
  media       InfraMedia[]
  meterReadings MeterReading[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([buildingId])
}

model InfraAccess {
  id           String     @id @default(cuid())
  infraPointId String
  infraPoint   InfraPoint @relation(fields: [infraPointId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation("infraAccess", fields: [userId], references: [id], onDelete: Cascade)
  @@unique([infraPointId, userId])
  @@index([infraPointId])
}

enum InfraMediaType {
  IMAGE
  VIDEO
}

model InfraMedia {
  id           String     @id @default(cuid())
  infraPointId String
  infraPoint   InfraPoint @relation(fields: [infraPointId], references: [id], onDelete: Cascade)
  type         InfraMediaType @default(IMAGE)
  url          String
  cdnPath      String
  name         String?
  createdAt    DateTime   @default(now())
  @@index([infraPointId])
}

model Contact {
  id          String   @id @default(cuid())
  buildingId  String
  building    Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  name        String
  category    String?
  phone       String?
  email       String?
  notes       String?
  createdAt   DateTime @default(now())
  @@index([buildingId])
}

enum TaskFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
  CUSTOM
}

model RecurringTask {
  id          String   @id @default(cuid())
  buildingId  String
  building    Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  title       String
  frequency   TaskFrequency @default(MONTHLY)
  nextDueDate DateTime?
  lastDoneDate DateTime?
  vendor      String?
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([buildingId])
}

model BuildingExpense {
  id          String   @id @default(cuid())
  buildingId  String
  building    Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  month       String   // YYYY-MM
  category    String?
  amount      Decimal  @db.Decimal(10, 2)
  description String?
  receiptFileId String?
  receiptFile BuildingFile? @relation("expenseReceipt", fields: [receiptFileId], references: [id], onDelete: SetNull)
  categoryId     String?
  categoryRef    ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  supplierName   String?
  supplierVat    String?
  documentNumber String?
  documentDate   DateTime?
  netAmount      Decimal? @db.Decimal(10, 2)
  vatAmount      Decimal? @db.Decimal(10, 2)
  status         ExpenseStatus @default(CONFIRMED)
  tenantPct      Int      @default(0)
  ownerPct       Int      @default(100)
  ocrRaw         Json?
  ocrConfidence  Float?
  issuedMonth    String?  // YYYY-MM of the κοινόχρηστα issuance this expense was locked into
  paid           Boolean  @default(false)
  paymentMethod  ExpensePaymentMethod?
  paidAt         DateTime?
  paymentFileId  String?
  paymentFile    BuildingFile? @relation("expensePayment", fields: [paymentFileId], references: [id], onDelete: SetNull)
  meterReadings  MeterReading[]
  allocations    ExpenseAllocation[]
  createdAt   DateTime @default(now())
  @@index([buildingId])
  @@index([buildingId, month])
  @@index([categoryId])
}

model ExpenseCategory {
  id        String  @id @default(cuid())
  name      String
  code      String  @unique
  utilityType ExpenseUtilityType @default(NONE)
  defaultBasis DistributionBasis @default(GENERAL_MILLESIMES)
  defaultTenantPct Int @default(0)
  defaultOwnerPct  Int @default(100)
  active    Boolean @default(true)
  sortOrder Int     @default(0)
  expenses  BuildingExpense[]
  overrides BuildingCategoryOverride[]
  exclusions UnitCategoryExclusion[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BuildingCategoryOverride {
  id         String   @id @default(cuid())
  buildingId String
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  categoryId String
  category   ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tenantPct  Int
  ownerPct   Int
  distributionBasis DistributionBasis?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@unique([buildingId, categoryId])
  @@index([buildingId])
}

model UnitCategoryExclusion {
  id         String   @id @default(cuid())
  unitId     String
  unit       Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  categoryId String
  category   ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  @@unique([unitId, categoryId])
  @@index([unitId])
  @@index([categoryId])
}

model UnitHeatingReading {
  id              String   @id @default(cuid())
  buildingId      String
  building        Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unitId          String
  unit            Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  period          String   // YYYY-MM
  previousReading Decimal? @db.Decimal(12, 3)
  currentReading  Decimal? @db.Decimal(12, 3)
  consumption     Decimal? @db.Decimal(12, 3)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@unique([unitId, period])
  @@index([buildingId, period])
}

model MeterReading {
  id             String   @id @default(cuid())
  buildingId     String
  building       Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  infraPointId   String?
  infraPoint     InfraPoint? @relation(fields: [infraPointId], references: [id], onDelete: SetNull)
  expenseId      String?
  expense        BuildingExpense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  meterType      MeterType
  meterNumber    String?
  periodFrom     DateTime?
  periodTo       DateTime?
  previousReading Decimal? @db.Decimal(12,3)
  currentReading  Decimal? @db.Decimal(12,3)
  consumption     Decimal? @db.Decimal(12,3)
  unit           String?
  createdAt      DateTime @default(now())
  @@index([buildingId])
  @@index([infraPointId])
}

model ExpenseAllocation {
  id           String  @id @default(cuid())
  expenseId    String
  expense      BuildingExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  unitId       String
  unit         Unit    @relation(fields: [unitId], references: [id], onDelete: Cascade)
  unitShare    Decimal @db.Decimal(10,2)
  breakdownNote String?
  tenantUserId String?
  tenantAmount Decimal @db.Decimal(10,2) @default(0)
  tenantPaid   Boolean @default(false)
  tenantPaidAt DateTime?
  tenantPaymentMethod ExpensePaymentMethod?
  ownerUserId  String?
  ownerAmount  Decimal @db.Decimal(10,2) @default(0)
  ownerPaid    Boolean @default(false)
  ownerPaidAt  DateTime?
  ownerPaymentMethod ExpensePaymentMethod?
  createdAt    DateTime @default(now())
  @@index([expenseId])
  @@index([unitId])
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
}

model UnitPayment {
  id          String   @id @default(cuid())
  unitId      String
  unit        Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  month       String   // YYYY-MM
  amount      Decimal  @db.Decimal(10, 2)
  status      PaymentStatus @default(PENDING)
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@unique([unitId, month])
  @@index([unitId])
}

// Per-scope manager (διαχειριστής) assignment. Grants PROPERTY_ADMIN-level
// management of ONE property or ONE building. A user may hold many assignments
// (manage multiple scopes) and still be an owner/resident elsewhere.
model ManagementAssignment {
  id          String    @id @default(cuid())

  userId      String
  user        User      @relation("userManagements", fields: [userId], references: [id], onDelete: Cascade)

  // Exactly one of propertyId / buildingId is set (property-level or building-level).
  propertyId  String?
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  buildingId  String?
  building    Building? @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  role        UserRole  @default(PROPERTY_ADMIN)

  createdAt   DateTime  @default(now())

  @@unique([userId, propertyId, buildingId])
  @@index([userId])
  @@index([propertyId])
  @@index([buildingId])
}

// Common areas (κοινόχρηστοι χώροι) — drive PER_COMMON_AREA pricing.
model CommonArea {
  id                    String   @id @default(cuid())

  buildingId            String
  building              Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  name                  String
  type                  String?
  floor                 Int?
  notes                 String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([buildingId])
}

// Units - apartments, shops, parking spaces
model Unit {
  id                    String   @id @default(cuid())

  buildingId            String
  building              Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  // Basic info
  unitNumber            String
  unitType              UnitType @default(APARTMENT)
  floor                 Int?
  areaSqm               Float?   // τετραγωνικά
  millesimes            Float?   // χιλιοστά (for κοινόχρηστα distribution)
  millesimesElevator    Float?
  millesimesHeating     Float?
  millesimesSource          MillesimeSource @default(AUTO)
  millesimesElevatorSource  MillesimeSource @default(AUTO)
  millesimesHeatingSource   MillesimeSource @default(AUTO)
  categoryExclusions    UnitCategoryExclusion[]
  heatingReadings       UnitHeatingReading[]

  // Ownership
  ownerId               String?
  owner                 User?    @relation("owner", fields: [ownerId], references: [id], onDelete: SetNull)

  residentId            String?
  resident              User?    @relation("resident", fields: [residentId], references: [id], onDelete: SetNull)

  // Relations
  maintenanceRequests   MaintenanceRequest[]
  payments              UnitPayment[]
  occupancies           UnitOccupancy[]
  expenseAllocations    ExpenseAllocation[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([buildingId, unitNumber])
  @@index([buildingId])
  @@index([ownerId])
  @@index([residentId])
}

// Service catalog (provider-defined) — each service has a pricing model.
model Service {
  id                    String   @id @default(cuid())

  companyId             String
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name                  String
  code                  String   @unique
  description           String?
  isCore                Boolean  @default(false)
  pricingModel          ServicePricingModel
  price                 Decimal  @db.Decimal(10, 2) // monthly rate / unit rate
  active                Boolean  @default(true)

  propertyServices      PropertyService[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([companyId])
}

// PropertyService — a service enabled on a Property (the package).
model PropertyService {
  id                    String   @id @default(cuid())

  propertyId            String
  property              Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  serviceId             String
  service               Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  active                Boolean  @default(true)
  startedAt             DateTime?
  endedAt               DateTime?

  // For METERED_PREPAID (assemblies): prepaid balance in person-minutes.
  prepaidPersonMinutes  Int      @default(0)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([propertyId, serviceId])
  @@index([propertyId])
  @@index([serviceId])
}

// Monthly service invoice issued by the provider to a Customer.
model ServiceInvoice {
  id                    String   @id @default(cuid())

  customerId            String
  customer              Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  period                String   // "YYYY-MM"
  amount                Decimal  @db.Decimal(10, 2)
  status                InvoiceStatus @default(PENDING)

  issuedAt              DateTime @default(now())
  dueDate               DateTime?
  paidAt                DateTime?
  vivaOrderRef          String?  // provider Viva transaction reference

  lines                 ServiceInvoiceLine[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([customerId, period])
  @@index([customerId])
  @@index([status])
}

model ServiceInvoiceLine {
  id                    String   @id @default(cuid())

  invoiceId             String
  invoice               ServiceInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description           String
  qty                   Int      @default(1)
  unitPrice             Decimal  @db.Decimal(10, 2)
  amount                Decimal  @db.Decimal(10, 2)

  @@index([invoiceId])
}

// User Company Role - for multi-role support
model UserCompanyRole {
  id                    String   @id @default(cuid())

  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyId             String
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  role                  UserRole
  department            String?  // For MANAGER/EMPLOYEE
  position              String?  // For EMPLOYEE

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
}

// Menu Configuration - SUPER_ADMIN configures menus per role
model MenuConfig {
  id                    String   @id @default(cuid())

  companyId             String?
  company               Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  role                  UserRole
  menuItems             Json     // Array of menu item objects
  isDefault             Boolean  @default(true)

  createdById           String?
  createdBy             User?    @relation("menuConfigCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([companyId, role])
  @@index([role])
}

// Announcements - digital signage content
model Announcement {
  id                    String   @id @default(cuid())

  buildingId            String
  building              Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  title                 String
  content               String   @db.Text   // rich text (HTML)
  imageUrl              String?  // BunnyCDN URL

  status                String   @default("ACTIVE") // ACTIVE, DRAFT, ARCHIVED
  audience              String   @default("ALL") // ALL, OWNERS, RESIDENTS, CUSTOM

  publishedAt           DateTime?
  expiresAt             DateTime?

  recurringTaskId       String?  // optional linked calendar entry

  createdById           String?
  createdBy             User?    @relation("announcementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  recipients            Announcement_User[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([buildingId])
  @@index([status])
}

model Announcement_User {
  id                    String       @id @default(cuid())
  announcementId        String
  announcement          Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId                String
  user                  User         @relation("announcementAcks", fields: [userId], references: [id], onDelete: Cascade)

  token                 String       @unique @default(cuid())
  sentAt                DateTime?
  readAt                DateTime?
  acknowledgedAt        DateTime?
  ipAddress             String?
  userAgent             String?

  @@unique([announcementId, userId])
  @@index([userId])
}

enum AssemblyStatus {
  SCHEDULED
  LIVE
  ENDED
  TRANSCRIBING
  DRAFT_READY
  APPROVED
  SENT
  CANCELLED
}

model Assembly {
  id              String          @id @default(cuid())
  buildingId      String
  building        Building        @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  title           String
  scheduledAt     DateTime
  status          AssemblyStatus  @default(SCHEDULED)
  dailyRoomName   String
  dailySessionId  String?
  transcriptRaw   String?         @db.Text
  minutesDraft    String?         @db.Text
  minutesFinal    String?         @db.Text
  approvedAt      DateTime?
  sentAt          DateTime?
  createdById     String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  participants    AssemblyParticipant[]

  @@index([buildingId])
  @@index([status])
}

model AssemblyParticipant {
  id              String    @id @default(cuid())
  assemblyId      String
  assembly        Assembly  @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  userId          String?
  unitId          String?
  email           String?   // for invited guests/test participants without an app account
  isHost          Boolean   @default(false)
  displayName     String
  joinedAt        DateTime?
  leftAt          DateTime?
  durationSeconds Int       @default(0)
  invitedSentAt   DateTime?
  momSentAt       DateTime?

  @@index([assemblyId])
  @@index([userId])
}

// Webhook replay protection — one row per processed delivery (id = sha256 of the signed string)
model ProcessedWebhook {
  id        String   @id
  source    String   @default("daily")
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// API Usage Tracking - for cost monitoring
model APIUsageLog {
  id                    String   @id @default(cuid())

  // API details
  apiName               String   // 'mailgun', 'bunnycdn', 'deepseek', 'gemini'
  endpoint              String?  // e.g., '/send-email', '/upload-file', '/translate'
  model                 String?  // e.g., 'deepseek-chat', 'gemini-pro'

  // Usage metrics
  requestCount          Int      @default(1)
  tokensUsed            Int?     // For LLM APIs
  bytesProcessed        Int?     // For storage/bandwidth
  costPerUnit           Float    // Cost per request/token/byte in EUR
  totalCost             Float    // Total cost in EUR
  currency              String   @default("EUR")

  // Metadata
  companyId             String?  // Which company triggered this (null = system)
  company               Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  userId                String?  // Which user triggered this
  user                  User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  buildingId            String?
  customerId            String?
  assemblyId            String?

  status                String   @default("SUCCESS") // SUCCESS, FAILED, RETRY
  errorMessage          String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([apiName])
  @@index([companyId])
  @@index([userId])
  @@index([createdAt])
  @@index([buildingId])
  @@index([customerId])
  @@index([assemblyId])
}

// API Cost Settings - configurable by SUPER_ADMIN
model APICostConfig {
  id                    String   @id @default(cuid())

  // API pricing
  apiName               String   @unique
  displayName           String   // "Mailgun", "BunnyCDN", "Deepseek", "Gemini"

  // Pricing structure
  costModel             String   // 'per_request', 'per_token', 'per_gb', 'per_email'
  basePrice             Float    // Cost per unit in EUR
  freeQuota             Int      @default(0) // Free units per month
  quotaResetDay         Int      @default(1) // Day of month to reset quota

  // Markup
  markupPercent         Float    @default(0) // % added on top of real cost for admin-facing billing

  // Limits
  monthlyBudgetLimit    Float?   // Optional budget cap in EUR
  enabled               Boolean  @default(true)

  // Metadata
  notes                 String?  @db.Text
  documentationUrl      String?

  updatedAt             DateTime @updatedAt
  updatedBy             String?  // SUPER_ADMIN user ID

  @@index([apiName])
}

// Monthly Cost Summary - pre-calculated for faster reporting
model MonthlyCostSummary {
  id                    String   @id @default(cuid())

  year                  Int
  month                 Int
  apiName               String

  requestCount          Int      @default(0)
  tokensUsed            Int      @default(0)
  bytesProcessed        Int      @default(0)
  totalCost             Float    @default(0)

  companyId             String?
  company               Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  createdAt             DateTime @default(now())

  @@unique([year, month, apiName, companyId])
  @@index([companyId])
}

// Maintenance Requests - core feature
model MaintenanceRequest {
  id                    String   @id @default(cuid())

  buildingId            String
  building              Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  unitId                String?
  unit                  Unit?    @relation(fields: [unitId], references: [id], onDelete: SetNull)

  title                 String
  description           String   @db.Text

  category              String   // 'plumbing', 'electrical', 'general', etc.
  priority              String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  status                String   @default("OPEN") // OPEN, IN_PROGRESS, COMPLETED, CANCELLED

  reportedById          String?
  reportedBy            User?    @relation("maintenanceReportedBy", fields: [reportedById], references: [id], onDelete: SetNull)

  assignedToId          String?
  assignedTo            User?    @relation("maintenanceAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  attachmentUrl         String?  // BunnyCDN URL

  scheduledDate         DateTime?
  completedAt           DateTime?
  notes                 String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([buildingId])
  @@index([unitId])
  @@index([status])
  @@index([priority])
}

// CMS Content Models for public website

model CMSPage {
  id                    String   @id @default(cuid())
  slug                  String   @unique // e.g., 'home', 'privacy', 'terms'
  title                 String
  content               String   @db.Text
  metaDescription       String?
  metaKeywords          String?
  publishedAt           DateTime?
  status                String   @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  i18n                  Json?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([slug])
  @@index([status])
}

model FAQ {
  id                    String   @id @default(cuid())
  question              String
  answer                String   @db.Text
  category              String   @default("general") // general, billing, features, technical
  order                 Int      @default(0)
  published             Boolean  @default(true)
  i18n                  Json?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([category])
  @@index([published])
  @@index([order])
}

model PricingTier {
