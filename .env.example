# Database
DATABASE_URL=postgresql://user:password@localhost:5432/property_management

# Auth.js / NextAuth
AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-hex-32
AUTH_URL=http://localhost:3000

# Mailgun Email Service
MAILGUN_DOMAIN=your-mailgun-domain.mailgun.org
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_FROM_EMAIL=noreply@your-mailgun-domain.mailgun.org

# Modulus SMS Service
MODULUS_API_KEY=your-modulus-api-key
MODULUS_API_URL=https://api.modulussms.gr

# BunnyCDN
BUNNY_API_KEY=your-bunny-api-key
BUNNY_STORAGE_ZONE=your-storage-zone
BUNNY_CDN_URL=https://your-storage-zone.b-cdn.net

# Viva Payments
VIVA_API_KEY=your-viva-api-key
VIVA_MERCHANT_ID=your-viva-merchant-id
VIVA_ENV=sandbox
# Viva Smart Checkout v2 (OAuth2 client credentials)
VIVA_CLIENT_ID=your-viva-smart-checkout-client-id
VIVA_CLIENT_SECRET=your-viva-smart-checkout-client-secret
VIVA_SOURCE_CODE=your-viva-source-code
VIVA_WEBHOOK_KEY=optional-fallback-webhook-verification-key

# Application
NEXT_PUBLIC_APP_NAME=Property Management
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
